{
  "name": "shop-saas",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack multi-tenant commerce SaaS monorepo.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:admin": "pnpm --filter @shop-saas/admin-web dev",
    "dev:server": "pnpm --filter @shop-saas/api-server dev",
    "build": "turbo build",
    "build:admin": "pnpm --filter @shop-saas/admin-web build",
    "build:server": "pnpm --filter @shop-saas/api-server build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@shop-saas/config": "workspace:*",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
